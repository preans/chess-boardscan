{
  "name": "boardscan",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "start": "concurrently -k -n vite,wrangler -c cyan,magenta \"vite\" \"wrangler pages dev --proxy=5173\"",
    "build": "tsc -b && vite build",
    "preview": "vite preview --host",
    "deploy": "npm run build && wrangler pages deploy dist",
    "typecheck": "tsc -b --noEmit"
  },
  "dependencies": {
    "chess.js": "^1.4.0",
    "heic-to": "^1.4.2",
    "react": "^18.3.1",
    "react-chessboard": "^4.7.3",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260424.1",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.3",
    "autoprefixer": "^10.4.20",
    "concurrently": "^9.2.1",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.15",
    "typescript": "^5.6.3",
    "vite": "^5.4.11",
    "vite-plugin-pwa": "^0.21.0",
    "wrangler": "^4.85.0"
  }
}
